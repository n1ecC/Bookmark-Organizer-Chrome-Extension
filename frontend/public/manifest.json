{
    "manifest_version": 3,
    "name": "AI Bookmark Organizer",
    "version": "1.0.2",
    "description": "Organize your bookmarks using AI with Google Gemini.",
    "permissions": [
        "storage",
        "unlimitedStorage",
        "bookmarks",
        "downloads",
        "sidePanel"
    ],
    "host_permissions": [
        "https://openrouter.ai/*"
    ],
    "action": {
        "default_title": "Organize Bookmarks"
    },
    "side_panel": {
        "default_path": "index.html"
    },
    "minimum_chrome_version": "114",
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    }
}